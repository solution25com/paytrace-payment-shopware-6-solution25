<template payTrace-payment-credit-card-plugin></template>
<div id="payTrace_payment" data-payTrace-credit-card="true"
     data-client-key="{{ page.extensions.payTrace_payment.clientKey }}"
     data-amount="{{ page.extensions.payTrace_payment.amount }}">

  <form>
    <div id='pt_hpf_form'></div>
    <input type="button" id="ProtectForm" value="Pay {{ page.cart.price.totalPrice|currency }}"
           class="btn btn-primary btn-block w-100">

    <div id="paymentLoader" style="display: none; text-align: center;">
      <img src="https://media3.giphy.com/media/v1.Y2lkPTc5MGI3NjExbjF6bWI3c3l2OHAzemprODJyZGZkdHp3MmIxN2U3NDh6bTQ2Y3ZzbCZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9Zw/emySgWo0iBKWqni1wR/giphy.gif" alt="Loading..." />
    </div>

  </form>

  <style>
      #paymentLoader {
          position: fixed;
          top: 0;
          left: 0;
          width: 100%;
          height: 100%;
          background-color: rgba(0, 0, 0, 0.5);
          display: none;
          justify-content: center;
          align-items: center;
          z-index: 9999;
      }

      #paymentLoader img {
          width: 100px;
          height: 100px;
      }
  </style>

  <script src='https://protect.sandbox.paytrace.com/js/protect.min.js'></script>
</div>
